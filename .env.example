# Copy to `.env` and fill in. The server reads these at runtime.

# REQUIRED — Supabase anon/public API key.
# Supabase Dashboard → Project Settings → API → Project API keys → `anon` `public`.
# Sent server-side as `Authorization: Bearer ...` and `apikey` to the edge function;
# never exposed to the browser.
SUPABASE_ANON_KEY=

# OPTIONAL — sensible defaults are baked in; override only if they change.
# SUPABASE_FUNCTION_URL=https://usstijzdensmlyanlwxr.supabase.co/functions/v1/submit-contact-form
# SUPABASE_TENANT_ID=8fb30c88-4769-46fc-922e-90f22db52c2f
